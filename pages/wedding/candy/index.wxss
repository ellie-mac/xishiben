.summary-card { margin-top: 0; }
.summary-row { display: flex; margin-bottom: 20rpx; }
.summary-item { flex: 1; text-align: center; }
.summary-val { font-size: 36rpx; font-weight: 700; color: #C9956C; }
.summary-val.spent { color: #66BB6A; }
.summary-val.remaining { color: #42A5F5; }
.summary-label { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.summary-divider { width: 1rpx; background: #F5EDE8; }

.item-list { padding: 0 32rpx; }
.candy-item { padding: 24rpx; margin-bottom: 0rpx; }
.item-header { display: flex; align-items: flex-start; }
.check-area { padding-top: 4rpx; margin-right: 20rpx; }
.check-circle {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  border: 3rpx solid #ddd; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}
.check-circle.checked {
  background: linear-gradient(135deg, #E8B4B8, #C9956C);
  border-color: #C9956C;
}

.item-body { flex: 1; }
.item-name { font-size: 30rpx; font-weight: 600; color: #333; }
.item-name.purchased { color: #bbb; text-decoration: line-through; }
.item-details { font-size: 24rpx; color: #999; margin-top: 8rpx; display: flex; flex-wrap: wrap; }
.item-notes { font-size: 24rpx; color: #bbb; margin-top: 8rpx; }

.item-actions { display: flex; gap: 8rpx; margin-left: 16rpx; }
.action-icon { font-size: 36rpx; padding: 4rpx; }

.form-group { margin-bottom: 24rpx; }
