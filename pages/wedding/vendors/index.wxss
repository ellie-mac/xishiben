.cat-scroll { padding: 16rpx 32rpx; white-space: nowrap; }
.cat-list { display: inline-flex; gap: 16rpx; }
.cat-item {
  display: inline-block; padding: 12rpx 24rpx;
  border-radius: 40rpx; font-size: 24rpx; color: #888;
  background: #f5f5f5; transition: all 0.2s; white-space: nowrap;
}
.cat-item.active { background: #C9956C; color: #fff; }

.vendor-list { padding: 0 32rpx; }
.vendor-card { margin-bottom: 0; }
.vendor-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.vendor-type-tag {
  background: #FEF3E2; color: #C9956C; font-size: 22rpx;
  padding: 6rpx 16rpx; border-radius: 20rpx;
}
.status-badge {
  font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 20rpx;
}
.status-pending { background: #F5F5F5; color: #999; }
.status-confirmed { background: #E8F5E9; color: #66BB6A; }
.status-paid { background: #E3F2FD; color: #42A5F5; }

.vendor-name { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }
.vendor-meta { background: #FDF8F5; border-radius: 12rpx; padding: 16rpx 20rpx; margin-bottom: 16rpx; }
.meta-item { font-size: 24rpx; color: #666; margin-bottom: 8rpx; display: flex; align-items: flex-start; }
.meta-item:last-child { margin-bottom: 0; }
.meta-label { color: #bbb; flex-shrink: 0; }
.phone-link { color: #C9956C; text-decoration: underline; }
.price-text { color: #C9956C; font-weight: 600; font-size: 28rpx; }

.vendor-actions { display: flex; gap: 16rpx; }
.action-btn {
  flex: 1; text-align: center; font-size: 26rpx;
  padding: 16rpx 0; border-radius: 20rpx;
}
.edit-btn { background: #FEF3E2; color: #C9956C; }
.del-btn { background: #FEE8ED; color: #E8B4B8; }

.form-group { margin-bottom: 24rpx; }
