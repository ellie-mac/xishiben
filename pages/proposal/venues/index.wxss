.tab-bar {
  display: flex;
  margin: 0 32rpx 20rpx;
  background: #f5f0eb;
  border-radius: 16rpx;
  padding: 6rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: #888;
  border-radius: 12rpx;
  transition: all 0.2s;
}
.tab-item.active {
  background: #fff;
  color: #C9956C;
  font-weight: 600;
  box-shadow: 0 2rpx 10rpx rgba(201,149,108,0.15);
}

.cat-scroll { padding: 0 32rpx 16rpx; white-space: nowrap; }
.cat-list { display: inline-flex; gap: 16rpx; }
.cat-item {
  display: inline-block; padding: 12rpx 28rpx;
  border-radius: 40rpx; font-size: 26rpx; color: #888;
  background: #f5f5f5; transition: all 0.2s;
}
.cat-item.active { background: #C9956C; color: #fff; }

.venue-card { margin-bottom: 0rpx; }
.venue-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16rpx; }
.venue-name { font-size: 32rpx; font-weight: 600; color: #333; }
.btn-copy {
  background: linear-gradient(135deg, #E8B4B8, #C9956C);
  color: #fff; font-size: 24rpx; border-radius: 30rpx;
  padding: 12rpx 24rpx; border: none; flex-shrink: 0;
  margin-left: 16rpx;
}
.venue-desc { font-size: 26rpx; color: #666; line-height: 1.7; margin-bottom: 16rpx; }
.venue-meta { background: #FDF8F5; border-radius: 12rpx; padding: 16rpx 20rpx; }
.meta-row { font-size: 24rpx; color: #888; margin-bottom: 8rpx; display: flex; }
.meta-row:last-child { margin-bottom: 0; }
.meta-label { color: #bbb; flex-shrink: 0; }
.meta-budget { color: #C9956C; font-weight: 500; }
.meta-tips { color: #666; flex: 1; }

.action-btns { display: flex; gap: 12rpx; }
.action-btn { font-size: 24rpx; padding: 10rpx 20rpx; border-radius: 20rpx; }
.edit-btn { background: #FEF3E2; color: #C9956C; }
.del-btn { background: #FEE8ED; color: #E8B4B8; }

.form-group { margin-bottom: 24rpx; }
