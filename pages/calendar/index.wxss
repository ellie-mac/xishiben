.calendar-card { padding: 24rpx; }

.cal-nav {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 20rpx;
}
.nav-btn {
  font-size: 48rpx; color: #C9956C; padding: 0 20rpx; line-height: 1;
}
.cal-title { font-size: 32rpx; font-weight: 600; color: #333; }

.week-header {
  display: grid; grid-template-columns: repeat(7, 1fr);
  margin-bottom: 8rpx;
}
.week-cell {
  text-align: center; font-size: 22rpx; color: #999; padding: 8rpx 0;
}
.week-cell.sun, .week-cell.sat { color: #E8B4B8; }

.day-grid {
  display: grid; grid-template-columns: repeat(7, 1fr); gap: 4rpx;
}
.day-cell {
  aspect-ratio: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  border-radius: 12rpx; position: relative; padding: 4rpx 0;
  transition: all 0.15s;
}
.day-cell.empty { }
.day-num { font-size: 26rpx; color: #333; line-height: 1; }
.day-lunar { font-size: 18rpx; color: #bbb; margin-top: 2rpx; }
.auspicious-dot {
  width: 8rpx; height: 8rpx; border-radius: 50%;
  background: #C9956C; margin-top: 2rpx;
}

.day-cell.auspicious { background: #FEF3E2; }
.day-cell.auspicious .day-num { color: #C9956C; font-weight: 600; }

.day-cell.today { background: #FEE8ED; }
.day-cell.today .day-num { color: #E8B4B8; font-weight: 700; }

.day-cell.selected {
  background: linear-gradient(135deg, #E8B4B8, #C9956C) !important;
  box-shadow: 0 4rpx 16rpx rgba(201,149,108,0.4);
}
.day-cell.selected .day-num { color: #fff !important; }
.day-cell.selected .day-lunar { color: rgba(255,255,255,0.8); }

.legend-row {
  display: flex; gap: 40rpx; justify-content: center;
  margin-top: 20rpx; padding-top: 16rpx;
  border-top: 1rpx solid #F5EDE8;
}
.legend-item { display: flex; align-items: center; gap: 8rpx; font-size: 22rpx; color: #999; }
.legend-dot { width: 20rpx; height: 20rpx; border-radius: 4rpx; }
.auspicious-legend { background: #FEF3E2; border: 2rpx solid #C9956C; }
.today-legend { background: #FEE8ED; border: 2rpx solid #E8B4B8; }

/* Date detail */
.date-detail { margin-top: 0; }
.detail-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.detail-date { font-size: 36rpx; font-weight: 700; color: #333; }
.auspicious-badge {
  background: linear-gradient(135deg, #E8B4B8, #C9956C);
  color: #fff; font-size: 24rpx; padding: 8rpx 20rpx; border-radius: 20rpx;
}
.normal-badge {
  background: #f5f5f5; color: #999; font-size: 24rpx;
  padding: 8rpx 20rpx; border-radius: 20rpx;
}
.lunar-info { display: flex; gap: 24rpx; flex-wrap: wrap; }
.lunar-item { font-size: 26rpx; color: #666; }

/* Saved dates */
.saved-list { padding: 0 32rpx; }
.saved-item { display: flex; align-items: center; padding: 24rpx; }
.saved-info { flex: 1; }
.saved-date { font-size: 30rpx; font-weight: 600; color: #333; }
.saved-lunar { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.saved-auspicious {
  display: inline-block; font-size: 20rpx; color: #C9956C;
  background: #FEF3E2; padding: 4rpx 12rpx; border-radius: 12rpx; margin-top: 8rpx;
}
.saved-del { color: #ddd; font-size: 28rpx; padding: 8rpx; }
