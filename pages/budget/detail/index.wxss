.summary-card { margin-top: 0; }
.summary-row { display: flex; flex-wrap: wrap; }
.summary-item { flex: 1; min-width: 0; text-align: center; padding: 8rpx 0; }
.summary-val { font-size: 30rpx; font-weight: 700; }
.summary-val.budget { color: #C9956C; }
.summary-val.estimated { color: #E88B4B; }
.summary-val.actual { color: #333; }
.summary-val.unpaid { color: #42A5F5; }
.summary-label { font-size: 20rpx; color: #999; margin-top: 4rpx; }
.summary-divider { width: 1rpx; background: #F5EDE8; }

.bar-label-row { display: flex; justify-content: space-between; }
.progress-fill.estimated-bar { background: linear-gradient(90deg, #FFD180, #E88B4B); }

.item-list { padding: 0 32rpx; }
.detail-item { padding: 24rpx; }
.item-header { display: flex; align-items: flex-start; margin-bottom: 16rpx; }
.paid-toggle { margin-right: 20rpx; padding-top: 4rpx; }
.check-circle {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  border: 3rpx solid #ddd; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}
.check-circle.checked {
  background: linear-gradient(135deg, #E8B4B8, #C9956C);
  border-color: #C9956C;
}

.item-info { flex: 1; }
.item-name { font-size: 30rpx; font-weight: 600; color: #333; }
.item-name.paid { color: #bbb; text-decoration: line-through; }
.item-date { font-size: 22rpx; color: #bbb; margin-top: 6rpx; }
.item-notes { font-size: 22rpx; color: #bbb; margin-top: 4rpx; }

.item-amounts { text-align: right; min-width: 120rpx; }
.item-actual { font-size: 32rpx; font-weight: 700; color: #C9956C; }
.item-estimated { font-size: 28rpx; color: #E88B4B; }
.item-estimated.small { font-size: 20rpx; color: #ccc; margin-top: 4rpx; }

.item-actions { display: flex; gap: 16rpx; }
.action-btn {
  flex: 1; text-align: center; font-size: 24rpx;
  padding: 14rpx 0; border-radius: 20rpx;
}
.edit-btn { background: #FEF3E2; color: #C9956C; }
.del-btn { background: #FEE8ED; color: #E8B4B8; }

.paid-toggle-row {
  display: flex; justify-content: space-between; align-items: center;
}
.toggle {
  width: 72rpx; height: 40rpx; border-radius: 20rpx;
  background: #ddd; position: relative; transition: background 0.2s;
}
.toggle::after {
  content: ''; position: absolute;
  width: 32rpx; height: 32rpx; border-radius: 50%;
  background: #fff; top: 4rpx; left: 4rpx;
  transition: left 0.2s;
}
.toggle.on { background: #C9956C; }
.toggle.on::after { left: 36rpx; }

.placeholder { color: #ccc; }
.form-group { margin-bottom: 24rpx; }
