.tab-bar {
  display: flex; margin: 0 32rpx 20rpx;
  background: #f5f0eb; border-radius: 16rpx; padding: 6rpx;
}
.tab-item {
  flex: 1; text-align: center; padding: 18rpx 0;
  font-size: 26rpx; color: #888; border-radius: 12rpx; transition: all 0.2s;
}
.tab-item.active {
  background: #fff; color: #C9956C; font-weight: 600;
  box-shadow: 0 2rpx 10rpx rgba(201,149,108,0.15);
}

/* 攻略 */
.guide-card { }
.guide-title {
  font-size: 30rpx; font-weight: 600; color: #333;
  margin-bottom: 16rpx; padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F5EDE8;
}
.guide-content {
  font-size: 26rpx; color: #555; line-height: 1.9;
  white-space: pre-wrap;
}

/* 清单 */
.cat-scroll { padding: 0 32rpx 16rpx; white-space: nowrap; }
.cat-list { display: inline-flex; gap: 16rpx; }
.cat-item {
  display: inline-block; padding: 12rpx 24rpx;
  border-radius: 40rpx; font-size: 24rpx; color: #888;
  background: #f5f5f5; white-space: nowrap;
}
.cat-item.active { background: #C9956C; color: #fff; }

.task-list { padding: 0 32rpx; }
.task-item {
  display: flex; align-items: flex-start;
  background: #fff; border-radius: 20rpx; padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(201,149,108,0.06);
}
.task-body { flex: 1; margin: 0 20rpx; }
.task-title { font-size: 28rpx; color: #333; font-weight: 500; }
.task-title.checked { color: #bbb; text-decoration: line-through; }
.task-desc { font-size: 24rpx; color: #999; margin-top: 8rpx; line-height: 1.5; }
.task-del { color: #ddd; font-size: 28rpx; padding: 4rpx 8rpx; }

.bottom-btns {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; padding: 24rpx 32rpx 60rpx;
  background: #fff; box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.06);
}

.tpl-item {
  display: flex; align-items: center; padding: 24rpx 0;
  border-bottom: 1rpx solid #F5EDE8;
}
.tpl-tag { margin-right: 16rpx; flex-shrink: 0; }
.tpl-title { flex: 1; font-size: 28rpx; color: #333; }
.tpl-add { color: #C9956C; font-size: 40rpx; padding: 0 10rpx; }

.form-group { margin-bottom: 24rpx; }
