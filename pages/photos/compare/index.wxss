.shop-list { padding: 0 32rpx; }
.shop-card { padding: 28rpx; }
.shop-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8rpx; }
.shop-name { font-size: 32rpx; font-weight: 600; color: #333; }
.shop-rating { display: flex; }
.star { font-size: 28rpx; color: #ddd; }
.star.filled { color: #C9956C; }

.shop-price {
  font-size: 44rpx; font-weight: 700; color: #C9956C;
  margin-bottom: 20rpx;
}

.detail-grid {
  display: flex; flex-wrap: wrap; gap: 16rpx;
  background: #FDF8F5; border-radius: 16rpx; padding: 20rpx;
  margin-bottom: 16rpx;
}
.detail-cell {
  flex: 1; min-width: 120rpx; text-align: center;
}
.detail-val { font-size: 28rpx; font-weight: 600; color: #333; }
.detail-label { font-size: 22rpx; color: #999; margin-top: 4rpx; }

.shop-locations, .shop-notes {
  font-size: 24rpx; color: #666; margin-bottom: 12rpx; display: flex;
}
.meta-label { color: #bbb; flex-shrink: 0; }

.shop-actions { display: flex; gap: 16rpx; margin-top: 16rpx; }
.action-btn {
  flex: 1; text-align: center; font-size: 26rpx;
  padding: 16rpx 0; border-radius: 20rpx;
}
.edit-btn { background: #FEF3E2; color: #C9956C; }
.del-btn { background: #FEE8ED; color: #E8B4B8; }

.rating-row { display: flex; gap: 16rpx; padding: 8rpx 0; }
.rating-star { font-size: 48rpx; color: #ddd; }
.rating-star.active { color: #C9956C; }

.toggle-row {
  display: flex; justify-content: space-between; align-items: center;
  cursor: pointer;
}
.toggle {
  width: 72rpx; height: 40rpx; border-radius: 20rpx;
  background: #ddd; position: relative; transition: background 0.2s;
}
.toggle::after {
  content: ''; position: absolute;
  width: 32rpx; height: 32rpx; border-radius: 50%;
  background: #fff; top: 4rpx; left: 4rpx;
  transition: left 0.2s;
}
.toggle.on { background: #C9956C; }
.toggle.on::after { left: 36rpx; }

.form-group { margin-bottom: 24rpx; }
